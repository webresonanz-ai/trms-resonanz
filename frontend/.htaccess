<IfModule mod_rewrite.c>
RewriteEngine On

# API routes
RewriteRule ^api/(.*)$ backend/index.php [L,QSA]

# Serve existing files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback
RewriteRule ^ index.html [L]

</IfModule>

Options -MultiViews
Options -Indexes